6. Create a package shapes with modules for circle and rectangle
Folder Structure
shapes/
    __init__.py
    circle.py
    rectangle.py

main.py
File: circle.py
def area(radius):
    return 3.14 * radius * radius

File: rectangle.py
def area(length, width):
    return length * width

File: main.py
from shapes.circle import area as circle_area
from shapes.rectangle import area as rectangle_area

print("Circle Area =", circle_area(5))
print("Rectangle Area =", rectangle_area(4, 6))
