7. Create a class with private attributes and getter/setter methods
class Student:
    def __init__(self):
        self.__marks = 0

    def set_marks(self, marks):
        self.__marks = marks

    def get_marks(self):
        return self.__marks

s = Student()

s.set_marks(90)
print("Marks:", s.get_marks())
---------------------------------------------------------------------------------------------
