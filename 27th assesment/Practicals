5. Business Queries

1. Display all students
SELECT * FROM students;

2. Display students present today
SELECT s.student_name
FROM students s
JOIN attendance a
ON s.student_id = a.student_id
WHERE a.status='Present';

3. Total payments received
SELECT SUM(amount) AS total_payment
FROM payments;

4. Find absent students
SELECT s.student_name
FROM students s
JOIN attendance a
ON s.student_id=a.student_id
WHERE a.status='Absent';

5. Show menu of Boys Mess
SELECT item_name
FROM menu
WHERE mess_id=101;

6. Count total students
SELECT COUNT(*) FROM students;

7. Average payment
SELECT AVG(amount) FROM payments;

8. Highest payment
SELECT MAX(amount) FROM payments;

9. Students from CSE department
SELECT * FROM students
WHERE department='CSE';

10. Attendance count
SELECT status,COUNT(*)
FROM attendance
GROUP BY status;

11. Students who paid more than 3000
SELECT s.student_name
FROM students s
JOIN payments p
ON s.student_id=p.student_id
WHERE p.amount>3000;

12. Department-wise student count
SELECT department,COUNT(*)
FROM students
GROUP BY department;

13. Monthly collection
SELECT MONTH(payment_date),SUM(amount)
FROM payments
GROUP BY MONTH(payment_date);

14. Students with no payment
SELECT s.student_name
FROM students s
LEFT JOIN payments p
ON s.student_id=p.student_id
WHERE p.payment_id IS NULL;

15. Total menu items
SELECT COUNT(*) FROM menu;
