Mess Management System Database Design
1. Create Database
CREATE DATABASE mess_management;
USE mess_management;

2. Tables
Students Table
CREATE TABLE students (
    student_id INT PRIMARY KEY,
    student_name VARCHAR(50),
    department VARCHAR(30),
    year INT,
    phone VARCHAR(15)
);
Mess Table
CREATE TABLE mess (
    mess_id INT PRIMARY KEY,
    mess_name VARCHAR(50),
    location VARCHAR(50)
);
Menu Table
CREATE TABLE menu (
    menu_id INT PRIMARY KEY,
    mess_id INT,
    meal_type VARCHAR(20),
    item_name VARCHAR(50),
    price INT,
    FOREIGN KEY (mess_id) REFERENCES mess(mess_id)
);
Attendance Table
CREATE TABLE attendance (
    attendance_id INT PRIMARY KEY,
    student_id INT,
    mess_id INT,
    attend_date DATE,
    status VARCHAR(10),
    FOREIGN KEY (student_id) REFERENCES students(student_id),
    FOREIGN KEY (mess_id) REFERENCES mess(mess_id)
);
Payment Table
CREATE TABLE payments (
    payment_id INT PRIMARY KEY,
    student_id INT,
    amount INT,
    payment_date DATE,
    FOREIGN KEY (student_id) REFERENCES students(student_id)
);


3. Relationships
One Student → Many Payments
One Student → Many Attendance Records
One Mess → Many Menu Items
One Mess → Many Attendance Records


