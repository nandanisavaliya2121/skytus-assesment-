1. Create a Car class with attributes like brand, model, and speed, and methods to accelerate/brake
class Car:
    def __init__(self, brand, model, speed):
        self.brand = brand
        self.model = model
        self.speed = speed

    def accelerate(self):
        self.speed += 10
        print("Speed:", self.speed)

    def brake(self):
        self.speed -= 10
        print("Speed:", self.speed)

c = Car("Toyota", "Innova", 50)

c.accelerate()
c.brake()
