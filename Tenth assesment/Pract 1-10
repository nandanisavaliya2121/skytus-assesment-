3. Create a Student class with a method to calculate average marks
class Student:
    def __init__(self, m1, m2, m3):
        self.m1 = m1
        self.m2 = m2
        self.m3 = m3

    def average(self):
        avg = (self.m1 + self.m2 + self.m3) / 3
        print("Average Marks:", avg)

s = Student(80, 90, 85)
s.average()
